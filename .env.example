# Enterprise Auth Service - Environment Configuration Template
# Copy this file to .env and update with your actual values
# IMPORTANT: Never commit .env file with real secrets to version control

# ============================================================================
# CORE APPLICATION SETTINGS
# ============================================================================

# Django settings
DEBUG=False
SECRET_KEY=your-super-secret-key-change-me-in-production
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
APP_ENV=development

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# PostgreSQL connection
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/enterprise_auth_dev
POSTGRES_DB=enterprise_auth_dev
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Database pool configuration
DATABASE_POOL_SIZE=20
DATABASE_POOL_RECYCLE=3600
DATABASE_POOL_PRE_PING=True

# ============================================================================
# CACHE & MESSAGE BROKER
# ============================================================================

# Redis configuration
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Celery broker (using Redis)
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_TASK_SERIALIZER=json
CELERY_RESULT_SERIALIZER=json
CELERY_ACCEPT_CONTENT=json
CELERY_TIMEZONE=UTC

# ============================================================================
# SECURITY & AUTHENTICATION
# ============================================================================

# CORS settings
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://localhost:8000

# JWT/Token settings
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
TOKEN_ALGORITHM=HS256

# OAuth2 providers (optional)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# ============================================================================
# EMAIL CONFIGURATION
# ============================================================================

# Email backend settings
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-email-password
DEFAULT_FROM_EMAIL=noreply@enterprise-auth.local

# Email settings
EMAIL_TIMEOUT=10
EMAIL_VERIFICATION_ENDPOINT=http://localhost:8000/api/v1/auth/verify-email

# ============================================================================
# AWS CONFIGURATION (Optional)
# ============================================================================

# AWS credentials for S3, SES, etc.
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_STORAGE_BUCKET_NAME=enterprise-auth-bucket
AWS_S3_CUSTOM_DOMAIN=cdn.example.com

# ============================================================================
# LOGGING & MONITORING
# ============================================================================

# Logging configuration
LOG_LEVEL=INFO
LOG_FORMAT=verbose
LOG_TO_FILE=False
LOG_FILE_PATH=/var/log/enterprise-auth-service/app.log

# Sentry error tracking
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# Prometheus metrics
PROMETHEUS_ENABLED=True
METRICS_PORT=9090

# ============================================================================
# THIRD-PARTY SERVICES
# ============================================================================

# Stripe integration (optional)
STRIPE_PUBLIC_KEY=pk_test_your-stripe-public-key
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key

# Twilio SMS (optional)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# SendGrid (alternative email provider)
SENDGRID_API_KEY=your-sendgrid-api-key

# ============================================================================
# DEVELOPMENT & TESTING
# ============================================================================

# Testing configuration
TESTING=False
TEST_DATABASE_NAME=test_enterprise_auth
PYTEST_ADDOPTS=--cov=src --cov-report=html

# Feature flags
FEATURE_OAUTH2_ENABLED=True
FEATURE_MULTI_TENANCY_ENABLED=False
FEATURE_API_RATE_LIMITING_ENABLED=True

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================

# Server settings
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
WORKERS=4
WORKER_CLASS=uvicorn.workers.UvicornWorker
WORKER_TIMEOUT=120

# ============================================================================
# API CONFIGURATION
# ============================================================================

# API settings
API_VERSION=v1
API_TITLE=Enterprise Auth Service
API_DESCRIPTION=Production-ready Authentication & User Management API
API_BASE_URL=http://localhost:8000/api/v1

# Rate limiting
RATE_LIMIT_ENABLED=True
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=3600

# Pagination defaults
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# ============================================================================
# DEPLOYMENT
# ============================================================================

# Deployment settings
DEPLOYMENT_ENV=development
DEPLOYMENT_REGION=us-east-1
DEPLOYMENT_VERSION=0.1.0

# Health check configuration
HEALTH_CHECK_ENABLED=True
HEALTH_CHECK_PATH=/health
